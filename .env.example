# ============================================================================
# Jobbed – Beispiel-Umgebungsvariablen
# Kopiere diese Datei zu `.env` und passe die Werte an. Committe niemals `.env`.
# ============================================================================

# ----- PostgreSQL -----
POSTGRES_DB=jobbed
POSTGRES_USER=jobbed
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_PORT=5432

# ----- Backend -----
# Aktives Spring-Profil: dev | prod
SPRING_PROFILES_ACTIVE=dev
DEMO_DATA_ENABLED=true
BACKEND_PORT=8080
# JDBC-URL zeigt im Compose-Netz auf den Service "postgres"
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/jobbed
SPRING_DATASOURCE_USERNAME=jobbed
SPRING_DATASOURCE_PASSWORD=change-me-in-prod

# ----- JWT / Auth -----
# Starkes, zufälliges Secret (min. 32 Byte, Base64). NUR Beispielwert!
JWT_SECRET=please-generate-a-strong-base64-secret-of-at-least-32-bytes
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
# Cookie-Einstellungen fuer Refresh-Token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Strict
APP_FRONTEND_BASE_URL=http://localhost

# ----- CORS -----
# Erlaubte Frontend-Origin(s), kommagetrennt
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80

# ----- E-Mail (Mailpit lokal) -----
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=no-reply@jobbed.local
MAILPIT_UI_PORT=8025
# Für Produktion zusätzlich setzen:
# MAIL_USERNAME=
# MAIL_PASSWORD=

# ----- Datei-Speicher (lokal) -----
FILE_STORAGE_TYPE=local
FILE_STORAGE_LOCAL_PATH=/app/uploads
FILE_UPLOAD_MAX_SIZE_MB=10

# ----- KI (optional; ohne Key bleibt die regelbasierte Analyse aktiv) -----
AI_PROVIDER=disabled
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-5-mini

# ----- Frontend -----
FRONTEND_PORT=80

# ----- Optional: MinIO (nicht standardmaessig aktiv) -----
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
