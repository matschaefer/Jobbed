<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Muster inkl. Correlation-ID (aus MDC). Keine Secrets/Tokens loggen! -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%X{correlationId:-no-corr-id}] [%t] %logger{36} - %msg%n"/>

    <!-- dev/test: menschenlesbar auf der Konsole -->
    <springProfile name="dev,test,default">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- prod: kompakt/strukturiert (kann später auf JSON-Encoder umgestellt werden) -->
    <springProfile name="prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.jobbed" level="INFO"/>
    </springProfile>
</configuration>
