DOMAIN=jobbed.example.com
POSTGRES_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-at-least-32-random-bytes

# SMTP-Zugang eines Transaktionsmail-Anbieters mit verifiziertem Absender
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-me
MAIL_PASSWORD=replace-me
MAIL_FROM=no-reply@jobbed.example.com

FILE_UPLOAD_MAX_SIZE_MB=10
DEMO_MODE_ENABLED=true
DEMO_MODE_EMAIL=demo@jobbed.local

# Optional
AI_PROVIDER=disabled
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-5-mini
